{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    ".specify/**",
    ".claude/**",
    ".vscode/**",
    ".github/agents/**",
    ".agents/**",
    "specs/**",
    "node_modules/**",
    "dist/**",
    "coverage/**",
    "CHANGELOG.md"
  ],
  "overrides": [
    {
      "files": ["**/*.md"],
      "options": {
        "proseWrap": "preserve"
      }
    }
  ]
}
